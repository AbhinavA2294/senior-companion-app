    "faq":  {
                "pageTitle":  "अक्सर पूछे जाने वाले प्रश्न",
                "subtitle":  "उत्तर नहीं मिला? {support} पर संपर्क करें या {phone} पर कॉल करें।",
                "stillHaveQuestions":  "अभी भी प्रश्न हैं?",
                "contactSupport":  "सहायता से संपर्क करें",
                "cat1":  "सेवा के बारे में",
                "q1_1_q":  "सीनियर कम्पेनियन क्या है?",
                "q1_1_a":  "सीनियर कम्पेनियन वरिष्ठों और उनके परिवारों को प्रशिक्षित, पृष्ठभूमि-जाँचे गए साथियों से जोड़ता है।",
                "q1_2_q":  "एक साथी क्या करता है?",
                "q1_2_a":  "एक साथी मित्रवत साहचर्य प्रदान करता है और दौरे के दौरान वरिष्ठ की सुरक्षा सुनिश्चित करता है।",
                "q1_3_q":  "एक साथी क्या नहीं करता?",
                "q1_3_a":  "साथी दवाएं नहीं देते, स्नान में मदद नहीं करते, व्यक्तिगत वाहन नहीं चलाते, पैसे नहीं संभालते।",
                "q1_4_q":  "क्या यह एक चिकित्सा सेवा है?",
                "q1_4_a":  "नहीं। सीनियर कम्पेनियन केवल एक साहचर्य सेवा है। चिकित्सा आपातकाल के लिए हमेशा 911 पर कॉल करें।",
                "cat2":  "बुकिंग",
                "q2_1_q":  "मुझे कितने समय पहले बुक करना होगा?",
                "q2_1_a":  "बुकिंग निर्धारित शुरुआती समय से कम से कम 12 घंटे पहले की जानी चाहिए।",
                "q2_2_q":  "एक बुकिंग कितने समय की हो सकती है?",
                "q2_2_a":  "बुकिंग 2 से 6 घंटे के बीच होती है। सेवा घंटे सुबह 8:00 – रात 8:00 बजे।",
                "q2_3_q":  "क्या कोई परिवार सदस्य किसी वरिष्ठ की ओर से बुक कर सकता है?",
                "q2_3_a":  "हाँ। परिवार के सदस्य खाता बना सकते हैं और वरिष्ठ की ओर से बुक कर सकते हैं।",
                "q2_4_q":  "क्या मैं बुकिंग रद्द कर सकता/सकती हूँ?",
                "q2_4_a":  "हाँ, बुकिंग शुरू होने से 24 घंटे पहले तक बिना शुल्क रद्द की जा सकती है।",
                "q2_5_q":  "साथियों को बुकिंग से कैसे मिलाया जाता है?",
                "q2_5_a":  "हमारा सिस्टम उपलब्धता, स्थान, भाषा और गतिविधि प्रकार के आधार पर साथियों का सुझाव देता है।",
                "cat3":  "सुरक्षा",
                "q3_1_q":  "साथियों की जाँच कैसे होती है?",
                "q3_1_a":  "सभी साथी पृष्ठभूमि जाँच पास करते हैं और हमारी टीम द्वारा मैन्युअल रूप से अनुमोदित होते हैं।",
                "q3_2_q":  "मुझे कैसे पता चलेगा कि साथी पहुँच गया?",
                "q3_2_a":  "साथी हर दौरे की शुरुआत में ऐप के माध्यम से चेक इन करते हैं।",
                "q3_3_q":  "आपातकाल में क्या होता है?",
                "q3_3_a":  "साथी को तुरंत 911 पर कॉल करने और फिर हमारी सहायता टीम को सूचित करने का निर्देश दिया गया है।",
                "q3_4_q":  "क्या मैं साथी की पहचान देख सकता/सकती हूँ?",
                "q3_4_a":  "हाँ। साथियों को हर दौरे के दौरान अपना सीनियर कम्पेनियन पहचान बैज पहनना आवश्यक है।",
                "cat4":  "भुगतान",
                "q4_1_q":  "भुगतान कैसे काम करता है?",
                "q4_1_a":  "सभी भुगतान बुकिंग के समय प्लेटफ़ॉर्म के माध्यम से सुरक्षित रूप से संसाधित होते हैं।",
                "q4_2_q":  "मूल्य निर्धारण क्या है?",
                "q4_2_a":  "मूल्य निर्धारण गतिविधि प्रकार और अवधि के अनुसार भिन्न होती है।",
                "q4_3_q":  "यदि मुझे धनवापसी की आवश्यकता हो तो?",
                "q4_3_a":  "पात्र रद्दीकरण के लिए धनवापसी 5-10 व्यावसायिक दिनों के भीतर संसाधित होती है।",
                "cat5":  "पायलट कार्यक्रम",
                "q5_1_q":  "पायलट कार्यक्रम क्या है?",
                "q5_1_a":  "सीनियर कम्पेनियन वर्तमान में एक छोटे सामुदायिक पायलट में है।",
                "q5_2_q":  "मैं फ़ीडबैक कैसे दूँ?",
                "q5_2_a":  "प्रत्येक पूर्ण दौरे के बाद, आपको ऐप में एक छोटा फ़ीडबैक फ़ॉर्म भरने के लिए आमंत्रित किया जाएगा।",
                "q5_3_q":  "कौन सी भाषाएँ समर्थित हैं?",
                "q5_3_a":  "प्लेटफ़ॉर्म अंग्रेज़ी, स्पेनिश, हिंदी, तमिल और कई अन्य भाषाओं का समर्थन करता है।"
            },
