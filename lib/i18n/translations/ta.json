    "faq":  {
                "pageTitle":  "அடிக்கடி கேட்கப்படும் கேள்விகள்",
                "subtitle":  "உங்கள் பதில் கிடைக்கவில்லையா? {support} இல் தொடர்புகொள்ளவும் அல்லது {phone} அழைக்கவும்.",
                "stillHaveQuestions":  "இன்னும் கேள்விகள் உள்ளனவா?",
                "contactSupport":  "ஆதரவை தொடர்புகொள்",
                "cat1":  "சேவையைப் பற்றி",
                "q1_1_q":  "சீனியர் கம்பேனியன் என்றால் என்ன?",
                "q1_1_a":  "சீனியர் கம்பேனியன் முதியவர்களையும் அவர்களது குடும்பங்களையும் பயிற்சிபெற்ற, பின்னணி சரிபார்க்கப்பட்ட துணைகளுடன் இணைக்கிறது.",
                "q1_2_q":  "ஒரு துணை என்ன செய்கிறார்?",
                "q1_2_a":  "ஒரு துணை நட்பான தோழமை வழங்குகிறார் மற்றும் வருகையின் போது முதியவரின் பாதுகாப்பை உறுதிசெய்கிறார்.",
                "q1_3_q":  "ஒரு துணை என்ன செய்வதில்லை?",
                "q1_3_a":  "துணைகள் மருந்து கொடுப்பதில்லை, குளிக்க உதவுவதில்லை, தனிப்பட்ட வாகனத்தை ஓட்டுவதில்லை, பணத்தை கையாள்வதில்லை.",
                "q1_4_q":  "இது ஒரு மருத்துவ சேவையா?",
                "q1_4_a":  "இல்லை. சீனியர் கம்பேனியன் மட்டும் தோழமை சேவை மட்டுமே. மருத்துவ அவசரநிலைக்கு எப்போதும் 911 அழைக்கவும்.",
                "cat2":  "பதிவுகள்",
                "q2_1_q":  "எவ்வளவு முன்பே பதிவு செய்ய வேண்டும்?",
                "q2_1_a":  "நியமிக்கப்பட்ட தொடக்க நேரத்திற்கு குறைந்தது 12 மணி நேரம் முன்பே பதிவு செய்ய வேண்டும்.",
                "q2_2_q":  "ஒரு பதிவு எவ்வளவு நேரம் இருக்கலாம்?",
                "q2_2_a":  "பதிவுகள் 2 முதல் 6 மணி நேரம் வரை இருக்கலாம். சேவை நேரம் காலை 8:00 – இரவு 8:00.",
                "q2_3_q":  "குடும்ப உறுப்பினர் முதியவரின் சார்பாக பதிவு செய்யலாமா?",
                "q2_3_a":  "ஆம். குடும்ப உறுப்பினர்கள் கணக்கு உருவாக்கி முதியவரின் சார்பாக பதிவு செய்யலாம்.",
                "q2_4_q":  "என்னால் பதிவை ரத்துசெய்ய முடியுமா?",
                "q2_4_a":  "ஆம், தொடக்க நேரத்திற்கு 24 மணி நேரம் முன்பு கட்டணமின்றி ரத்துசெய்யலாம்.",
                "q2_5_q":  "துணைகளை பதிவுகளுடன் எவ்வாறு பொருத்துகிறார்கள்?",
                "q2_5_a":  "எங்கள் அமைப்பு கிடைக்கும் தன்மை, இடம், மொழி மற்றும் செயல்பாட்டு வகை அடிப்படையில் பொருத்துகிறது.",
                "cat3":  "பாதுகாப்பு",
                "q3_1_q":  "துணைகள் எவ்வாறு சரிபார்க்கப்படுகிறார்கள்?",
                "q3_1_a":  "அனைத்து துணைகளும் பின்னணி சரிபார்ப்பை கடந்து எங்கள் குழுவால் கைமுறையாக அங்கீகரிக்கப்படுகிறார்கள்.",
                "q3_2_q":  "துணை வந்தார் என்று எனக்கு எப்படி தெரியும்?",
                "q3_2_a":  "துணைகள் ஒவ்வொரு வருகையின் தொடக்கத்திலும் பயன்பாட்டின் மூலம் சரிபார்க்கிறார்கள்.",
                "q3_3_q":  "அவசரநிலையில் என்ன நடக்கும்?",
                "q3_3_a":  "மருத்துவ அவசரநிலை ஏற்பட்டால், துணை உடனடியாக 911 அழைத்து பின்னர் ஆதரவு குழுவிடம் தெரிவிப்பார்.",
                "q3_4_q":  "துணையின் அடையாளத்தை பார்க்கலாமா?",
                "q3_4_a":  "ஆம். ஒவ்வொரு வருகையிலும் துணைகள் தங்கள் சீனியர் கம்பேனியன் அடையாள அட்டையை அணிந்திருக்க வேண்டும்.",
                "cat4":  "கொடுப்பனவுகள்",
                "q4_1_q":  "கொடுப்பனவுகள் எவ்வாறு செயல்படுகின்றன?",
                "q4_1_a":  "அனைத்து கொடுப்பனவுகளும் பதிவு நேரத்தில் தளத்தின் மூலம் பாதுகாப்பாக செயல்படுத்தப்படுகின்றன.",
                "q4_2_q":  "விலை நிர்ணயம் என்ன?",
                "q4_2_a":  "விலை நிர்ணயம் செயல்பாட்டு வகை மற்றும் கால அளவு அடிப்படையில் மாறுபடுகிறது.",
                "q4_3_q":  "திரும்பப்பெறல் தேவையெனில்?",
                "q4_3_a":  "தகுதியான ரத்துகளுக்கு திரும்பப்பெறல் 5-10 வணிக நாட்களுக்குள் செயல்படுத்தப்படும்.",
                "cat5":  "பைலட் திட்டம்",
                "q5_1_q":  "பைலட் திட்டம் என்றால் என்ன?",
                "q5_1_a":  "சீனியர் கம்பேனியன் தற்போது ஒரு சிறிய சமூக பைலட்டில் உள்ளது.",
                "q5_2_q":  "கருத்தை எவ்வாறு தெரிவிப்பது?",
                "q5_2_a":  "ஒவ்வொரு முடிந்த வருகைக்கும் பின்னர், பயன்பாட்டில் ஒரு சிறிய கருத்து படிவத்தை நிரப்ப அழைக்கப்படுவீர்கள்.",
                "q5_3_q":  "எந்த மொழிகள் ஆதரிக்கப்படுகின்றன?",
                "q5_3_a":  "தளம் ஆங்கிலம், ஸ்பானிஷ், இந்தி, தமிழ் மற்றும் பல மொழிகளை ஆதரிக்கிறது."
            },
